              "name": "List Payments",
              "request": {
                "method": "GET",
                "header": [
                  {"key": "X-API-Key", "value": "{{api_key}}"}
                ],
                "url": {
                  "raw": "{{core_base_url}}/api/{{merchant_id}}/payments?limit=50&offset=0",
                  "host": ["{{core_base_url}}"],
                  "path": ["api", "{{merchant_id}}", "payments"],
                  "query": [
                    {"key": "limit", "value": "50"},
                    {"key": "offset", "value": "0"}
                  ]
                },
                "description": "List all payments for a merchant tenant."
              },
              "response": []
            },
            {
              "name": "Get Payment",
              "request": {
                "method": "GET",
                "header": [
                  {"key": "X-API-Key", "value": "{{api_key}}"}
                ],
                "url": {
                  "raw": "{{core_base_url}}/api/{{merchant_id}}/payments/{{payment_id}}",
                  "host": ["{{core_base_url}}"],
                  "path": ["api", "{{merchant_id}}", "payments", "{{payment_id}}"]
                },
                "description": "Get a specific payment by UUID."
              },
              "response": []
            },
            {
              "name": "Update Payment",
              "request": {
                "method": "PUT",
                "header": [
                  {"key": "Content-Type", "value": "application/json"},
                  {"key": "X-API-Key", "value": "{{api_key}}"}
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"description\": \"Updated order description\",\n  \"metadata\": {\n    \"order_id\": \"ORD-12345\",\n    \"notes\": \"VIP customer\"\n  }\n}",
                  "options": {"raw": {"language": "json"}}
                },
                "url": {
                  "raw": "{{core_base_url}}/api/{{merchant_id}}/payments/{{payment_id}}",
                  "host": ["{{core_base_url}}"],
                  "path": ["api", "{{merchant_id}}", "payments", "{{payment_id}}"]
                },
                "description": "Update payment description and/or metadata. Status cannot be changed through this endpoint."
              },
              "response": []
            },
            {
              "name": "Authorize Payment",
              "request": {
                "method": "POST",
                "header": [
                  {"key": "X-API-Key", "value": "{{api_key}}"}
                ],
                "url": {
                  "raw": "{{core_base_url}}/api/{{merchant_id}}/payments/{{payment_id}}/authorize",
                  "host": ["{{core_base_url}}"],
                  "path": ["api", "{{merchant_id}}", "payments", "{{payment_id}}", "authorize"]
                },
                "description": "Transition a payment to 'authorized' state. Only valid from 'pending' state. Publishes a domain event to Kafka."
              },
              "response": []
            },
            {
              "name": "Capture Payment",
              "request": {
                "method": "POST",
                "header": [
                  {"key": "X-API-Key", "value": "{{api_key}}"}
                ],
                "url": {
                  "raw": "{{core_base_url}}/api/{{merchant_id}}/payments/{{payment_id}}/capture",
                  "host": ["{{core_base_url}}"],
                  "path": ["api", "{{merchant_id}}", "payments", "{{payment_id}}", "capture"]
                },
                "description": "Transition a payment to 'captured' state. Only valid from 'authorized' state. Publishes a domain event to Kafka."
              },
              "response": []
            },
            {
              "name": "Fail Payment",
              "request": {
                "method": "POST",
                "header": [
                  {"key": "X-API-Key", "value": "{{api_key}}"}
                ],
                "url": {
                  "raw": "{{core_base_url}}/api/{{merchant_id}}/payments/{{payment_id}}/fail",
                  "host": ["{{core_base_url}}"],
                  "path": ["api", "{{merchant_id}}", "payments", "{{payment_id}}", "fail"]
                },
                "description": "Mark a payment as 'failed'. Sets failure_reason to 'Payment declined'. Publishes a domain event to Kafka."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Refunds",
          "item": [
            {
              "name": "Create Refund",
              "request": {
