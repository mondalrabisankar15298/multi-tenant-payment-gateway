                },
                "url": {
                  "raw": "{{connect_base_url}}/api/webhooks",
                  "host": ["{{connect_base_url}}"],
                  "path": ["api", "webhooks"]
                },
                "description": "Register a new webhook endpoint to receive event notifications. Supported event_types: payment.captured, payment.failed, payment.authorized, refund.processed, etc."
              },
              "response": [
                {
                  "name": "Created",
                  "status": "Created",
                  "code": 201,
                  "header": [{"key": "Content-Type", "value": "application/json"}],
                  "body": "{\n  \"subscription_id\": 1,\n  \"merchant_id\": 1,\n  \"url\": \"https://your-server.com/webhooks/payment-events\",\n  \"event_types\": [\"payment.captured\", \"payment.failed\", \"refund.processed\"],\n  \"secret\": \"your-webhook-signing-secret\",\n  \"active\": true,\n  \"created_at\": \"2026-03-30T11:00:00Z\"\n}"
                }
              ]
            },
