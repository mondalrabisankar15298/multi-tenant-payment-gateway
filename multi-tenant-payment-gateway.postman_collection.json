                "description": "Process/finalize a pending refund. Transitions it to 'processed' status and publishes a refund domain event to Kafka."
              },
              "response": []
            },
            {
              "name": "List Refunds",
              "request": {
                "method": "GET",
                "header": [
                  {"key": "X-API-Key", "value": "{{api_key}}"}
                ],
                "url": {
                  "raw": "{{core_base_url}}/api/{{merchant_id}}/refunds?limit=50&offset=0",
