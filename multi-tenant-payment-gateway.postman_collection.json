                  "query": [
                    {"key": "limit", "value": "50"},
                    {"key": "offset", "value": "0"}
                  ]
                },
                "description": "List all refunds for a merchant tenant."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Events (Outbox)",
          "item": [
            {
              "name": "List Domain Events",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{core_base_url}}/api/events?limit=100",
                  "host": ["{{core_base_url}}"],
                  "path": ["api", "events"],
                  "query": [
                    {"key": "status", "value": "pending", "description": "pending | published | failed", "disabled": true},
                    {"key": "merchant_id", "value": "{{merchant_id}}", "description": "Filter by merchant", "disabled": true},
                    {"key": "entity_type", "value": "payment", "description": "payment | refund | customer | merchant", "disabled": true},
                    {"key": "event_type", "value": "payment.captured", "description": "Specific event type string", "disabled": true},
                    {"key": "from_date", "value": "2026-03-01T00:00:00Z", "description": "ISO timestamp from", "disabled": true},
                    {"key": "to_date", "value": "2026-03-31T23:59:59Z", "description": "ISO timestamp to", "disabled": true},
                    {"key": "limit", "value": "100", "description": "Max events to return"}
                  ]
                },
                "description": "Admin endpoint: view the domain_events outbox table with rich filter support. Used to monitor event publishing status and debug Kafka pipeline issues."
              },
              "response": []
            }
          ]
        }
      ]
