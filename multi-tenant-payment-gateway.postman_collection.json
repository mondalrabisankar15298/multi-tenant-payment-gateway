                  "raw": "{\n  \"merchant_id\": {{merchant_id}},\n  \"url\": \"https://your-server.com/webhooks/payment-events\",\n  \"event_types\": [\n    \"payment.captured\",\n    \"payment.failed\",\n    \"refund.processed\"\n  ],\n  \"secret\": \"your-webhook-signing-secret\"\n}",
