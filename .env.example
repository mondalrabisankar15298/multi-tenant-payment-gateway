# ─── Core DB (System 1 — Write) ───
CORE_DB_HOST=core-db
CORE_DB_PORT=5432
CORE_DB_USER=payment_admin
CORE_DB_PASSWORD=payment_secret
CORE_DB_NAME=payment_core

# ─── Read DB (System 3 — Read) ───
READ_DB_HOST=read-db
READ_DB_PORT=5432
READ_DB_USER=payment_admin
READ_DB_PASSWORD=payment_secret
READ_DB_NAME=payment_read

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── Redpanda / Kafka ───
KAFKA_BROKERS=redpanda:9092
KAFKA_TOPIC=payments.events

# ─── Outbox Worker ───
OUTBOX_POLL_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=50

# ─── Core DB Replica ───
CORE_DB_REPLICA_HOST=core-db-replica
CORE_DB_REPLICA_PORT=5432
REPLICATION_PASSWORD=repl_secret

# ─── OAuth / JWT ───
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=3600
ADMIN_API_KEY=dev-admin-key-change-in-production

# ─── Third-Party Webhooks ───
TP_WEBHOOK_MAX_RETRIES=6
TP_WEBHOOK_TIMEOUT_SECONDS=10
TP_WEBHOOK_VERIFY_ON_CREATE=true

# ─── Rate Limiting ───
RATE_LIMIT_DEFAULT_REQUESTS=1000
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=300
OAUTH_RATE_LIMIT_PER_MINUTE=10

# ─── Service Ports ───
CORE_SERVICE_PORT=8001
CONNECT_SERVICE_PORT=8002
DASHBOARD_SERVICE_PORT=8003
